function init(self)
	self.message = "hello"
	
	self.message_text = gui.get_node("message_text")
	self.keyboard = gui.get_node("Keyboard")
	
	self.keyboard_chars = string.len(self.message) -- counter for how many symbols the message contains
	gui.set_text(self.message_text, self.message) -- set the message to the text node

	msg.post(".", "acquire_input_focus")
end

function update(self, dt)
	-- easter eggs that don't change the code for typing

	local white = vmath.vector4(1, 1, 1, 1)
	local red = vmath.vector4(0.8, 0.2, 0.2, 1)
	local orange = vmath.vector4(1, 0.6, 0.2, 1)
	local yellow = vmath.vector4(1, 1, 0.4, 1)
	local green = vmath.vector4(0.4, 0.8, 0.2, 1)
	local cyan = vmath.vector4(0, 1, 1, 1)
	local blue = vmath.vector4(0.2, 0.4, 1, 1)
	local purple = vmath.vector4(0.6, 0.2, 1, 1)
	local pink = vmath.vector4(1, 0.4, 0.6, 1)
	local magenta = vmath.vector4(1, 0, 1, 1)
	local brown = vmath.vector4(0.6, 0.4, 0.2, 1)
	

	if self.message == "red" then
		gui.set_color(self.message_text, red)
	elseif self.message == "orange" then
		gui.set_color(self.message_text, orange)
	elseif self.message == "yellow" then
		gui.set_color(self.message_text, yellow)
	elseif self.message == "green" then
		gui.set_color(self.message_text, green)
	elseif self.message == "cyan" then
		gui.set_color(self.message_text, cyan)
	elseif self.message == "blue" then
		gui.set_color(self.message_text, blue)
	elseif self.message == "purple" then
		gui.set_color(self.message_text, purple)
	elseif self.message == "pink" then
		gui.set_color(self.message_text, pink)
	elseif self.message == "magenta" then
		gui.set_color(self.message_text, magenta)
	elseif self.message == "brown" then
		gui.set_color(self.message_text, brown)
	elseif self.message == "big" then
		gui.set_scale(self.message_text, vmath.vector3(3, 3, 1))
	elseif self.message == "small" then
		gui.set_scale(self.message_text, vmath.vector3(1, 1, 1))
	else
		gui.set_color(self.message_text, white)
		gui.set_scale(self.message_text, vmath.vector3(2, 2, 1))
	end

end

function on_input(self, action_id, action)
	if self.keyboard_chars >= 0 then

		if gui.pick_node(gui.get_node("keyboard_a"), action.x, action.y) then
			if action.pressed then
				gui.play_flipbook(gui.get_node("keyboard_a"), "Ap")
			elseif action.released then
				gui.play_flipbook(gui.get_node("keyboard_a"), "A")
				self.message = self.message .. "a"
				gui.set_text(self.message_text, self.message)
				self.keyboard_chars = string.len(self.message)
			end
		end

		if gui.pick_node(gui.get_node("keyboard_b"), action.x, action.y) then
