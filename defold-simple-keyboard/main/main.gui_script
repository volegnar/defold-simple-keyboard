				self.message = self.message .. "z"
				gui.set_text(self.message_text, self.message)
				self.keyboard_chars = string.len(self.message)
			end
		end

		if gui.pick_node(gui.get_node("keyboard_dot"), action.x, action.y) then
			if action.pressed then
				gui.play_flipbook(gui.get_node("keyboard_dot"), "Dotp")
			elseif action.released then
				gui.play_flipbook(gui.get_node("keyboard_dot"), "Dot")
				self.message = self.message .. "."
				gui.set_text(self.message_text, self.message)
				self.keyboard_chars = string.len(self.message)
			end
		end

		if gui.pick_node(gui.get_node("keyboard_space"), action.x, action.y) and self.keyboard_chars > 0 then -- !
			-- ! cannot enter space if no letter was added
			if action.pressed then
				gui.play_flipbook(gui.get_node("keyboard_space"), "Spacep")
			elseif action.released then
				gui.play_flipbook(gui.get_node("keyboard_space"), "Space")
				self.message = self.message .. " "
				gui.set_text(self.message_text, self.message)
				self.keyboard_chars = string.len(self.message)
			end
		end


		if gui.pick_node(gui.get_node("keyboard_delete"), action.x, action.y) and self.keyboard_chars > 0 then -- !
			-- ! cannot delete 0 letters
			if action.pressed then
				gui.play_flipbook(gui.get_node("keyboard_delete"), "Deletep")
			elseif action.released then
				gui.play_flipbook(gui.get_node("keyboard_delete"), "Delete")
				self.message = string.sub(self.message, 1, #self.message - 1)
				gui.set_text(self.message_text, self.message)
				self.keyboard_chars = string.len(self.message)
			end
		end

		if gui.pick_node(gui.get_node("keyboard_done"), action.x, action.y) then
			if action.pressed then
				gui.play_flipbook(gui.get_node("keyboard_done"), "Donep")
			elseif action.released then
				gui.play_flipbook(gui.get_node("keyboard_done"), "Done")
				if self.keyboard_chars == 0 then
					self.message = "hello" -- if everything is deleted, replace with "hello"
					gui.set_text(self.message_text, self.message)
					self.keyboard_chars = string.len(self.message)
				end
			end
		end


